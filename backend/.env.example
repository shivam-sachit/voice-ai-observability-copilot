# --- HighLevel (GHL) ---
# Private Integration Token for the sub-account, and the location (sub-account) id.
GHL_PIT=
GHL_LOCATION_ID=
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28

# --- Anthropic (Claude) --- used for KPI suggestion and transcript analysis.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Server ---
PORT=3000
DB_PATH=data/observability.db
# CORS allow-origin. '*' for local dev; set to the embed/frontend origin in production.
CORS_ORIGIN=*
